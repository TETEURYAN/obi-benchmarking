# Problem Understanding Service – environment variables
# Copy to .env and adjust. Required for LLM calls.

# LLM model (PydanticAI model string, e.g. openai:gpt-4o-mini, openai:gpt-4o)
LLM_MODEL=openai:gpt-4o-mini

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Environment: development | staging | production
ENVIRONMENT=development

# OpenAI (if using openai:* models)
# OPENAI_API_KEY=sk-...

# Optional: use Pydantic AI Gateway or another provider
# See https://ai.pydantic.dev/gateway
